---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.external)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));
---

<Layout title={`${post.data.title} · Ratul Dawar`} description={post.data.description}>
  <main>
    <article class="prose">
      <a href="/blog" class="back-link">← All posts</a>
      <header class="prose-header">
        <div class="pc-meta">
          <span class="card-tag">{post.data.tag}</span>
          <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
          <span class="dot-sep">·</span>
          <span class="read">{readingTime} min read</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="prose-lead">{post.data.description}</p>
      </header>
      <Content />
    </article>
  </main>
</Layout>
