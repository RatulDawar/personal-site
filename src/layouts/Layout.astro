    <script is:inline>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      const bar = document.getElementById('scrollbar');
      if (bar) {
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          bar.style.transform = `scaleX(${max > 0 ? h.scrollTop / max : 0})`;
        };
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      const typed = document.getElementById('typed');
      if (typed) {
        const roles = [
          'distributed systems, databases, and query engines.',
          'always building, always measuring.',
          'streaming petabytes in real time.',
          'open source, on the side.',
        ];
        let r = 0, c = 0, deleting = false;
        const tick = () => {
          const word = roles[r];
          typed.textContent = word.slice(0, c);
          if (!deleting && c < word.length) c++;
          else if (deleting && c > 0) c--;
          else if (!deleting && c === word.length) { deleting = true; setTimeout(tick, 1600); return; }
          else { deleting = false; r = (r + 1) % roles.length; }
          setTimeout(tick, deleting ? 35 : 70);
        };
        tick();
      }

      const counters = document.querySelectorAll('[data-count]');
      const cio = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target;
          const target = parseFloat(el.dataset.count);
          const suffix = el.dataset.suffix || '';
          let cur = 0;
          const step = target / 45;
          const run = () => {
            cur += step;
            if (cur >= target) { el.textContent = target + suffix; return; }
            el.textContent = Math.floor(cur) + suffix;
            requestAnimationFrame(run);
          };
          run();
          cio.unobserve(el);
        }
      }, { threshold: 0.5 });
      counters.forEach((el) => cio.observe(el));
    </script>

    <script is:inline>
      (function () {
        const canvas = document.getElementById('pixelbg');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const CELL = 17;
        const GAP = 5;
        const palette = [
          [240, 169, 59],
          [56, 217, 196],
          [139, 124, 240],
        ];

        let cols = 0, rows = 0, dpr = 1, W = 0, H = 0;
        let streams = [];
        let scrollNorm = 0;
        let targetScroll = 0;

        function lerp(a, b, t) { return a + (b - a) * t; }
        function mix(c1, c2, t) {
          return [lerp(c1[0], c2[0], t), lerp(c1[1], c2[1], t), lerp(c1[2], c2[2], t)];
        }
        function scrollColor(n) {
          const p = n * (palette.length - 1);
          const i = Math.min(palette.length - 2, Math.floor(p));
          return mix(palette[i], palette[i + 1], p - i);
        }

        function resize() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = window.innerWidth;
          H = window.innerHeight;
          canvas.width = W * dpr;
          canvas.height = H * dpr;
          canvas.style.width = W + 'px';
          canvas.style.height = H + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          cols = Math.ceil(W / CELL) + 1;
          rows = Math.ceil(H / CELL) + 1;
          initStreams();
        }

        function initStreams() {
          const count = Math.max(5, Math.floor(cols / 5));
          streams = [];
          for (let i = 0; i < count; i++) streams.push(makeStream(true));
        }
        function makeStream(spread) {
          return {
            col: Math.floor(Math.random() * cols),
            y: spread ? Math.random() * rows : -Math.random() * 12,
            speed: 4 + Math.random() * 9,
            len: 5 + Math.floor(Math.random() * 9),
            ci: Math.floor(Math.random() * palette.length),
          };
        }

        function onScroll() {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          targetScroll = max > 0 ? Math.min(1, Math.max(0, h.scrollTop / max)) : 0;
        }

        function patternValue(x, y, t, seg) {
          const cx = cols / 2, cy = rows / 2;
          const p0 = (Math.sin(x * 0.3 + t) + Math.cos(y * 0.32 - t * 0.8)) * 0.5; // waves
          const d = Math.hypot(x - cx, y - cy);
          const p1 = Math.sin(d * 0.45 - t * 1.6); // ripples from center
          const p2 = Math.sin((x + y) * 0.4 + t * 1.2); // diagonal bands
          const p3 = Math.sin(x * 0.55 + t) * Math.sin(y * 0.55 - t * 0.9); // grid/checker pulse
          const pats = [p0, p1, p2, p3, p0];
          const i = Math.floor(seg) % 4;
          const f = seg - Math.floor(seg);
          const e = f < 0.5 ? 2 * f * f : 1 - Math.pow(-2 * f + 2, 2) / 2;
          return pats[i] * (1 - e) + pats[i + 1] * e;
        }

        let last = 0;
        function frame(now) {
          const dt = Math.min(0.05, (now - last) / 1000 || 0);
          last = now;
          scrollNorm += (targetScroll - scrollNorm) * 0.08;

          const t = now / 1000;
          const seg = scrollNorm * 4;
          const accent = scrollColor(scrollNorm);

          ctx.clearRect(0, 0, W, H);

          const size = CELL - GAP;
          for (let x = 0; x < cols; x++) {
            for (let y = 0; y < rows; y++) {
              const v = patternValue(x, y, t, seg);
              const n = (v + 1) / 2;
              if (n < 0.42) continue;
              const a = Math.min(0.92, (n - 0.42) * 1.5);
              if (n > 0.78) {
                ctx.fillStyle = 'rgba(' + accent[0] + ',' + accent[1] + ',' + accent[2] + ',' + a.toFixed(3) + ')';
              } else {
                ctx.fillStyle = 'rgba(150,156,180,' + (a * 0.7).toFixed(3) + ')';
              }
              ctx.fillRect(x * CELL, y * CELL, size, size);
            }
          }

          ctx.font = (CELL - GAP) + 'px "JetBrains Mono", monospace';
          ctx.textBaseline = 'top';
          for (const s of streams) {
            s.y += s.speed * dt;
            const col = palette[s.ci];
            const headY = Math.floor(s.y);
            for (let k = 0; k < s.len; k++) {
              const cy = headY - k;
              if (cy < 0 || cy >= rows) continue;
              const fade = 1 - k / s.len;
              const isHead = k === 0;
              const a = fade * (isHead ? 0.85 : 0.4);
              ctx.fillStyle = 'rgba(' + col[0] + ',' + col[1] + ',' + col[2] + ',' + a.toFixed(3) + ')';
              const ch = Math.sin(s.col * 12.9 + cy * 4.7) > 0 ? '1' : '0';
              ctx.fillText(ch, s.col * CELL, cy * CELL);
            }
            if (s.y - s.len > rows) Object.assign(s, makeStream(false));
          }

          requestAnimationFrame(frame);
        }

        function staticFrame() {
          const size = CELL - GAP;
          ctx.clearRect(0, 0, W, H);
          for (let x = 0; x < cols; x++) {
            for (let y = 0; y < rows; y++) {
              const v = patternValue(x, y, 0, 0);
              const n = (v + 1) / 2;
              if (n < 0.5) continue;
              ctx.fillStyle = 'rgba(150,156,180,' + ((n - 0.5) * 0.9).toFixed(3) + ')';
              ctx.fillRect(x * CELL, y * CELL, size, size);
            }
          }
        }

        resize();
        window.addEventListener('resize', resize, { passive: true });
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
        if (reduced) staticFrame();
        else requestAnimationFrame(frame);
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
